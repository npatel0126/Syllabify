{
  "hosting": {
    "public": ".next",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "python312",
    "environmentVariables": {
      "FIRESTORE_EMULATOR_HOST": "127.0.0.1:8080",
      "FIREBASE_STORAGE_EMULATOR_HOST": "127.0.0.1:9199",
      "STORAGE_EMULATOR_HOST": "http://127.0.0.1:9199",
      "GCLOUD_PROJECT": "syllabify-9b9d4",
      "GOOGLE_CLOUD_PROJECT": "syllabify-9b9d4",
      "GEMINI_API_KEY": "REDACTED",
      "OBJC_DISABLE_INITIALIZE_FORK_SAFETY": "YES"
    }
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}