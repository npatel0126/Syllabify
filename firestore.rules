rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users document is scoped to the authenticated user.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Syllabi are scoped to the owning user.
    match /syllabi/{syllabusId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      // When creating, resource.data doesn't exist yet; keep reads/writes gated by user auth.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Assignments are scoped to the owning user.
    match /assignments/{assignmentId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Grades are scoped to the owning user.
    match /grades/{gradeId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

