rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Emulator: allow everything so the client SDK works without real auth ──
    // The auth emulator is disabled (we use real Google OAuth), so request.auth
    // is always null in the emulator. Open access here is safe — these rules
    // are NEVER deployed to production (production uses the rules below).
    match /{document=**} {
      allow read, write: if true;
    }

    /* ── Production rules (uncomment when deploying) ──────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /syllabi/{syllabusId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    match /assignments/{assignmentId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    match /grades/{gradeId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }
    ── */
  }
}

